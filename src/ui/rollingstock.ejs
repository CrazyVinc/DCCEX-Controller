<!DOCTYPE html>
<html lang="en" class="dark">

<head>
    <%- include('layout/head.ejs') %>
</head>

<body class="min-h-screen flex flex-col">

    <%- include('layout/header.ejs') %>
    <main class="mx-auto w-full max-w-6xl flex-1 px-4 py-8 sm:px-6 lg:px-8">
        <section id="trains">
            <div class="max-w-6xl mx-auto bg-[#161b22] border border-[#30363d] rounded-xl p-6 shadow-2xl">

                <div class="flex justify-between items-center mb-6">
                    <h1 class="text-[#ff9d00] text-2xl font-bold tracking-wider uppercase">Trains</h1>
                    <div class="flex gap-3">
                        <button type="button"
                            class="px-4 py-2 border border-[#00c896] text-[#00c896] rounded-lg text-sm font-bold uppercase hover:bg-[#00c8961a] transition-colors"
                            id="addTrain" onclick="document.getElementById('AddRollingStock').showModal()">
                            + Add Train
                        </button>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    <% rollingStock.trains.forEach((train) => { %>
                        <%- include('components/RollingStockCard.ejs', { train }) %>
                    <% }) %>
                </div>
            </div>
        </section>
        <section id="wagons" class="hidden">
            <% rollingStock.wagons.forEach((wagon) => { %>
                <%- include('components/RollingStockCard.ejs', { train: wagon }) %>
            <% }) %>
        </section>
    </main>
    <%- include('layout/footer.ejs') %>


    <dialog id="AddRollingStock"
        class="w-full max-w-lg rounded-lg border border-[#ff9d00] bg-[#0d1117] p-0 text-gray-300 shadow-xl backdrop:bg-gray-800/50 open:flex open:max-h-[min(90vh,900px)] open:flex-col m-auto fixed inset-0">

        <div class="flex max-h-[min(90vh,900px)] flex-col overflow-hidden">
            <header class="flex shrink-0 items-start justify-between gap-4 border-b border-[#30363d] px-5 py-4">

                <h2 class="text-lg font-bold uppercase tracking-wider text-[#ff9d00]">TRAIN</h2>

                <button id="train-dialog-close" method="dialog" class="m-0 p-0" aria-label="Close">&times;</button>
            </header>

            <form id="train-form" class="flex min-h-0 flex-1 flex-col" action="#" method="post">
                <div class="min-h-0 flex-1 overflow-y-auto px-5 py-4">
                    <div class="flex flex-col gap-5">
                        <div class="flex flex-col gap-1.5">
                            <label for="train-dcc-address"
                                class="text-xs font-medium uppercase tracking-wide text-gray-400">DCC
                                address (decoder)</label>

                            <input id="train-dcc-address" name="dccAddress" type="text" inputmode="numeric"
                                placeholder="3"
                                class="w-full rounded-md border border-[#30363d] bg-[#161b22] px-3 py-2 text-sm text-gray-200 placeholder:text-gray-500 focus:border-[#ff9d00] focus:outline-none focus:ring-1 focus:ring-[#ff9d00]" />
                        </div>

                        <div class="flex flex-col gap-1.5">
                            <label for="train-name"
                                class="text-xs font-medium uppercase tracking-wide text-gray-400">Train
                                name</label>
                            <p class="text-xs text-gray-500">What you see in the roster and cab (e.g. <span
                                    class="font-medium text-gray-400">Big Boy</span>). This does <span
                                    class="font-medium text-gray-400">not</span> change the DCC number.</p>
                            <input id="train-name" name="trainName" type="text" placeholder="BR003"
                                class="w-full rounded-md border border-[#30363d] bg-[#161b22] px-3 py-2 text-sm text-gray-200 placeholder:text-gray-500 focus:border-[#ff9d00] focus:outline-none focus:ring-1 focus:ring-[#ff9d00]" />
                        </div>

                        <div class="flex flex-col gap-1.5">
                            <label for="train-length-mm"
                                class="text-xs font-medium uppercase tracking-wide text-gray-400">Length
                                (mm)</label>

                            <p class="text-xs text-gray-500">
                                Full length in <span class="font-medium text-gray-400">millimeters</span>
                                — same unit as track segments in <code
                                    class="rounded bg-[#21262d] px-1 py-0.5 text-[11px] text-gray-400">layout.json</code>.
                                Do not enter meters (e.g. use <code
                                    class="rounded bg-[#21262d] px-1 py-0.5 text-[11px] text-gray-400">1200</code> for
                                1.2 m).
                            </p>

                            <input id="train-length-mm" name="lengthMm" type="text" inputmode="decimal"
                                placeholder="275"
                                class="w-full rounded-md border border-[#30363d] bg-[#161b22] px-3 py-2 text-sm text-gray-200 placeholder:text-gray-500 focus:border-[#ff9d00] focus:outline-none focus:ring-1 focus:ring-[#ff9d00]" />
                        </div>

                        <div class="flex flex-col gap-2">
                            <p class="text-xs font-medium uppercase tracking-wide text-gray-400">
                                Speed calibration at step 1
                            </p>

                            <p class="text-xs text-gray-500">
                                Time to cover a known distance (distance in cm; stored as mm/s) at Märklin speed step 1.
                            </p>

                            <div class="grid grid-cols-2 gap-4">
                                <div class="flex flex-col gap-1.5">
                                    <label for="train-cal-duration" class="text-xs text-gray-500">Duration (s)</label>
                                    <input id="train-cal-duration" name="calDurationSec" type="text" inputmode="decimal"
                                        placeholder="9"
                                        class="w-full rounded-md border border-[#30363d] bg-[#161b22] px-3 py-2 text-sm text-gray-200 placeholder:text-gray-500 focus:border-[#ff9d00] focus:outline-none focus:ring-1 focus:ring-[#ff9d00]" />
                                </div>

                                <div class="flex flex-col gap-1.5">
                                    <label for="train-cal-distance" class="text-xs text-gray-500">Distance (cm)</label>
                                    <input id="train-cal-distance" name="calDistanceCm" type="text" inputmode="decimal"
                                        placeholder="60"
                                        class="w-full rounded-md border border-[#30363d] bg-[#161b22] px-3 py-2 text-sm text-gray-200 placeholder:text-gray-500 focus:border-[#ff9d00] focus:outline-none focus:ring-1 focus:ring-[#ff9d00]" />
                                </div>
                            </div>

                            <div class="rounded-md border border-[#ff9d00] bg-[#161b22] px-3 py-3">
                                <p class="text-[10px] font-medium uppercase tracking-wide text-gray-500">
                                    Calculated speed (saved as mm/s)
                                </p>

                                <p class="mt-1 text-2xl font-semibold text-[#ff9d00]">
                                    <span id="train-cal-speed-value">—</span>
                                    <span class="text-base font-normal text-gray-400">mm/s</span>
                                </p>
                            </div>
                        </div>

                        <div class="flex flex-col gap-1.5">
                            <label for="train-start-delay"
                                class="text-xs font-medium uppercase tracking-wide text-gray-400">
                                Start delay (s)</label>

                            <p class="text-xs text-gray-500">
                                After you select a speed (e.g. step 1), some locs take this long before they actually
                                roll. Leave empty if none.
                            </p>

                            <input id="train-start-delay" name="startDelaySec" type="text" inputmode="decimal"
                                placeholder="optional"
                                class="w-full rounded-md border border-[#30363d] bg-[#161b22] px-3 py-2 text-sm text-gray-200 placeholder:text-gray-500 focus:border-[#ff9d00] focus:outline-none focus:ring-1 focus:ring-[#ff9d00]" />
                        </div>

                        <div class="flex items-start gap-3">
                            <input id="train-swap-fwd-rev" name="swapFwdRev" type="checkbox"
                                class="mt-0.5 h-4 w-4 shrink-0 rounded border-[#30363d] bg-[#161b22] text-[#ff9d00] focus:ring-[#ff9d00]" />

                            <label for="train-swap-fwd-rev"
                                class="text-sm uppercase leading-snug tracking-wide text-gray-400">
                                Swap FWD / REV (decoder direction inverted)
                            </label>
                        </div>

                        <div class="flex flex-col gap-1.5">
                            <label for="train-f-keys" class="text-xs font-medium uppercase tracking-wide text-gray-400">
                                F-keys (comma-separated, 1-28)
                            </label>

                            <input id="train-f-keys" name="fKeys" type="text" placeholder="1, 2, 3, 4"
                                class="w-full rounded-md border border-[#30363d] bg-[#161b22] px-3 py-2 text-sm text-gray-200 placeholder:text-gray-500 focus:border-[#ff9d00] focus:outline-none focus:ring-1 focus:ring-[#ff9d00]" />
                        </div>

                        <div class="flex flex-col gap-1.5">
                            <label for="train-notes"
                                class="text-xs font-medium uppercase tracking-wide text-gray-400">Notes</label>
                            <textarea id="train-notes" name="notes" rows="3"
                                class="w-full resize-y rounded-md border border-[#30363d] bg-[#161b22] px-3 py-2 text-sm text-gray-200 placeholder:text-gray-500 focus:border-[#ff9d00] focus:outline-none focus:ring-1 focus:ring-[#ff9d00]"></textarea>
                        </div>

                        <div class="flex flex-col gap-1.5">
                            <label for="train-metadata"
                                class="text-xs font-medium uppercase tracking-wide text-gray-400">Metadata
                                (JSON object)</label>
                            <textarea id="train-metadata" name="metadataJson" rows="3" placeholder="{}"
                                class="w-full resize-y rounded-md border border-[#30363d] bg-[#161b22] px-3 py-2 font-mono text-sm text-gray-200 placeholder:text-gray-500 focus:border-[#ff9d00] focus:outline-none focus:ring-1 focus:ring-[#ff9d00]"></textarea>
                        </div>

                        <!-- <div class="flex flex-col gap-1.5">
                            <span class="text-xs font-medium uppercase tracking-wide text-gray-400">Photos</span>
                            <p class="text-xs text-gray-500">
                                Add more with the file picker below; each new file uploads immediately. Remove deletes
                                that photo only.
                            </p>
                            <button type="button"
                                class="w-full rounded-md border border-[#30363d] bg-[#161b22] px-3 py-2 text-left text-sm text-gray-400 transition-colors hover:border-[#ff9d00] hover:text-gray-200">
                                Add image...
                            </button>
                        </div> -->
                    </div>
                </div>

                <footer
                    class="flex shrink-0 flex-wrap items-stretch gap-3 border-t border-[#30363d] bg-[#0d1117] px-5 py-4">
                    <button type="submit"
                        class="min-h-12 min-w-0 flex-1 rounded-md bg-[#00c896] px-4 py-3 text-center text-sm font-bold uppercase tracking-wide text-black transition-opacity hover:opacity-90">
                        Save
                    </button>

                    <button type="button"
                        class="min-h-12 shrink-0 rounded-md border-2 border-red-500 bg-[#161b22] px-4 py-3 text-sm font-bold uppercase tracking-wide text-red-500 transition-colors hover:bg-red-950/30">
                        Delete
                    </button>
                </footer>
            </form>
        </div>
    </dialog>

    <script>
        document.addEventListener('DOMContentLoaded', () => {

            // --- Modal ---
            const dialog = document.getElementById("AddRollingStock");
            dialog.addEventListener("click", e => e.target === dialog && dialog.close());
            document.getElementById("addTrain").addEventListener("click", () => dialog.showModal());
            document.getElementById("train-dialog-close").addEventListener("click", () => dialog.close());

            // --- Speed calculator ---
            const durationEl = document.getElementById('train-cal-duration');
            const distanceEl = document.getElementById('train-cal-distance');
            const speedOut = document.getElementById('train-cal-speed-value');

            function parseNum(raw) {
                const n = parseFloat(String(raw).trim().replace(',', '.'));
                return Number.isFinite(n) ? n : NaN;
            }

            function updateCalculatedSpeedMmPerS() {
                const durationSec = parseNum(durationEl.value);
                const distanceCm = parseNum(distanceEl.value);
                if (!(distanceCm > 0) || !(durationSec > 0)) {
                    speedOut.textContent = '—';
                    return;
                }
                speedOut.textContent = ((distanceCm * 10) / durationSec).toFixed(2);
            }

            if (durationEl && distanceEl && speedOut) {
                durationEl.addEventListener('input', updateCalculatedSpeedMmPerS);
                distanceEl.addEventListener('input', updateCalculatedSpeedMmPerS);
            }

            // --- Form submission ---
            const form = document.getElementById('train-form');

            function buildPayload(formData) {
                const duration = parseNum(formData.get('calDurationSec'));
                const distanceCm = parseNum(formData.get('calDistanceCm'));
                return {
                    DCC_ID: formData.get('dccAddress'),
                    Name: formData.get('trainName'),
                    Length: parseNum(formData.get('lengthMm')),
                    Speed: {
                        Duration: duration,
                        Distance: distanceCm,
                        Step: 1,
                        calculated: (distanceCm * 10) / duration
                    },
                    startDelay: parseNum(formData.get('startDelaySec')) || 0,
                    Functions: formData.get('fKeys').split(',').map(f => f.trim()).filter(f => f !== ''),
                    Notes: formData.get('notes'),
                    Meta: JSON.parse(formData.get('metadataJson') || '{}')
                };
            }

            async function submitTrain(e) {
                e.preventDefault();
                const payload = buildPayload(new FormData(form));
                const response = await fetch('/api/addTrain', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                if (response.ok) alert("Train saved!");
            }

            if (form) form.addEventListener('submit', submitTrain);
        });
    </script>
</body>

</html>
