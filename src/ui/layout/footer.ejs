<% if (devLiveReload) { %>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    var sawDisconnect = false;
    socket.on("connect", function () {
      if (sawDisconnect) {
        location.reload();
      }
    });
    socket.on("disconnect", function () {
      sawDisconnect = true;
    });
  });
</script>
<% } %>
<footer class="mt-auto border-t border-[var(--surface-border)] bg-[var(--surface)]">
  <div
    class="mx-auto flex max-w-6xl flex-col gap-2 px-4 py-6 text-sm text-[var(--muted)] sm:flex-row sm:items-center sm:justify-between sm:px-6 lg:px-8">
    <p class="order-2 sm:order-1">Model railway DCC control</p>
    <p class="order-1 font-medium text-[var(--page-fg)] sm:order-2">new-dcc-controller</p>
  </div>
</footer>
