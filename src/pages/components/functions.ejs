<%
const panelSize = typeof size === 'string' ? size : 'md';
const panelLayout = typeof layout === 'string' ? layout : 'portrait';
const hasTrains = typeof trains !== 'undefined' && Array.isArray(trains) && trains.length > 0;
const hasSingleTrain = typeof train !== 'undefined' && train;
const panelTrain = hasSingleTrain ? train : (hasTrains ? trains[0] : null);
const functionNumbers = panelTrain && Array.isArray(panelTrain.Functions) ? panelTrain.Functions.map((fn) => String(fn).trim()).filter((fn) => fn.length > 0) : [];
const isPortrait = panelLayout === 'portrait';
const buttonPadding = isPortrait
    ? (panelSize === 'lg' ? 'px-3.5 py-2' : 'px-3 py-1.5')
    : 'px-2.5 py-1.5';
const buttonTextSize = isPortrait
    ? (panelSize === 'lg' ? 'text-sm' : 'text-xs')
    : 'text-xs';
const trainsPayload = (hasTrains ? trains : (panelTrain ? [panelTrain] : [])).map((t) => ({
    DCC_ID: t.DCC_ID,
    Functions: Array.isArray(t.Functions) ? t.Functions : []
}));
const isFleetPanel = hasTrains;
const panelIdSuffix = isFleetPanel ? '' : (panelTrain ? String(panelTrain.DCC_ID).replace(/[^a-zA-Z0-9_-]/g, '_') : 'solo');
const rootDomId = isFleetPanel ? 'train-functions-root' : `train-functions-root-${panelIdSuffix}`;
const dataDomId = isFleetPanel ? 'train-functions-data' : `train-functions-data-${panelIdSuffix}`;
%>
<script type="application/json" id="<%= dataDomId %>"><%- JSON.stringify(trainsPayload) %></script>
<div
    id="<%= rootDomId %>"
    class="mt-4 <%= isPortrait ? 'grid grid-cols-2 gap-2.5' : 'flex w-full flex-nowrap gap-2 overflow-x-auto pb-1' %>"
    data-layout="<%= panelLayout %>"
    data-size="<%= panelSize %>"
    data-button-padding="<%= buttonPadding %>"
    data-button-text-size="<%= buttonTextSize %>"
    data-portrait="<%= isPortrait ? '1' : '0' %>"
>
    <% functionNumbers.forEach((fn) => { %>
    <button type="button" class="inline-flex <%= isPortrait ? 'min-w-14 rounded-lg' : 'shrink-0 rounded-md' %> cursor-pointer items-center justify-center border border-amber-500/50 bg-slate-900 font-semibold tracking-wide text-amber-300 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)] transition-colors <%= buttonPadding %> <%= buttonTextSize %>" data-function-number="<%= fn %>" data-train-id="<%= panelTrain ? panelTrain.DCC_ID : '' %>">
        <%= String(fn).toUpperCase().startsWith('F') ? fn : `F${fn}` %>
    </button>
    <% }) %>
</div>

<script>
    (function () {
        const root = document.getElementById('<%= rootDomId %>');
        const dataEl = document.getElementById('<%= dataDomId %>');
        if (!root || !dataEl) {
            return;
        }
        const isFleetPanel = <%= isFleetPanel ? 'true' : 'false' %>;

        let trainsData = [];
        try {
            trainsData = JSON.parse(dataEl.textContent || '[]');
        } catch {
            trainsData = [];
        }

        const portraitShape = 'inline-flex min-w-14 rounded-lg cursor-pointer items-center justify-center border border-amber-500/50 bg-slate-900 font-semibold tracking-wide text-amber-300 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)] transition-colors';
        const landscapeShape = 'inline-flex shrink-0 rounded-md cursor-pointer items-center justify-center border border-amber-500/50 bg-slate-900 font-semibold tracking-wide text-amber-300 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)] transition-colors';

        function labelForFn(fn) {
            const s = String(fn);
            return s.toUpperCase().startsWith('F') ? s : `F${s}`;
        }

        function renderForCab(cab) {
            const t = trainsData.find((x) => String(x.DCC_ID) === String(cab));
            const isPortrait = root.dataset.portrait === '1';
            const pad = root.dataset.buttonPadding || '';
            const textSz = root.dataset.buttonTextSize || '';
            const shapeClass = isPortrait ? portraitShape : landscapeShape;

            root.className = [
                'mt-4',
                isPortrait ? 'grid grid-cols-2 gap-2.5' : 'flex w-full flex-nowrap gap-2 overflow-x-auto pb-1',
            ].join(' ');

            if (!t) {
                root.replaceChildren();
                return;
            }

            const nums = (t.Functions || []).map((fn) => String(fn).trim()).filter((fn) => fn.length > 0);
            const frag = document.createDocumentFragment();
            for (const fn of nums) {
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.className = [shapeClass, pad, textSz].filter(Boolean).join(' ');
                btn.dataset.functionNumber = fn;
                btn.dataset.trainId = String(t.DCC_ID);
                btn.textContent = labelForFn(fn);
                frag.appendChild(btn);
            }
            root.replaceChildren(frag);
        }

        function syncToSelection() {
            const cab = typeof selectedTrain !== 'undefined' && selectedTrain !== null ? selectedTrain : null;
            if (cab !== null && trainsData.some((x) => String(x.DCC_ID) === String(cab))) {
                renderForCab(cab);
            } else if (trainsData[0]) {
                renderForCab(trainsData[0].DCC_ID);
            } else {
                renderForCab('');
            }
        }

        root.addEventListener('click', (event) => {
            const button = event.target.closest('button[data-function-number]');
            if (!button || !root.contains(button)) {
                return;
            }
            const functionNumber = button.dataset.functionNumber;
            const trainId = button.dataset.trainId;
            const isOn = button.dataset.isOn === 'true';
            const nextState = !isOn;

            button.dataset.isOn = String(nextState);
            button.classList.toggle('border-green-500', nextState);
            button.classList.toggle('text-green-300', nextState);
            button.classList.toggle('border-amber-500/50', !nextState);
            button.classList.toggle('text-amber-300', !nextState);

            socket.emit('dcc:function', { cab: trainId, function: functionNumber });
        });

        if (isFleetPanel) {
            document.addEventListener('selectedTrain:changed', (event) => {
                const cab = event?.detail?.cab;
                if (cab === undefined || cab === null) {
                    return;
                }
                if (trainsData.some((x) => String(x.DCC_ID) === String(cab))) {
                    renderForCab(cab);
                } else if (trainsData[0]) {
                    renderForCab(trainsData[0].DCC_ID);
                } else {
                    renderForCab('');
                }
            });

            syncToSelection();
        }
    })();
</script>
