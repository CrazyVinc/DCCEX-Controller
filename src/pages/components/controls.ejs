<% const speedStepLabels = [127, 96, 64, 32, 0]; %>

<div class="flex flex-wrap justify-center items-center gap-10 sm:gap-16 py-6">
  <div class="flex flex-col items-center">
    <div
      class="flex items-stretch gap-4 rounded-3xl border border-slate-700/90 bg-slate-900/95 px-5 py-6 shadow-[inset_0_1px_0_0_rgba(148,163,184,0.08)] sm:gap-5 sm:px-6">
      <div class="relative h-96 w-13 shrink-0 sm:h-112 sm:w-15">
        <div
          class="pointer-events-none absolute inset-0 rounded-full border-2 border-emerald-400 bg-black/85 shadow-[0_0_18px_rgba(52,211,153,0.45),0_0_42px_rgba(52,211,153,0.12)]">
        </div>
        <input id="forwardSpeed" type="range" min="0" max="127" step="1" value="0" aria-label="Forward speed"
          class="absolute left-1/2 top-1/2 w-96 max-w-none -translate-x-1/2 -translate-y-1/2 -rotate-90 cursor-pointer appearance-none accent-emerald-500 h-14 
          [&::-webkit-slider-runnable-track]:h-2 [&::-webkit-slider-runnable-track]:rounded-full [&::-webkit-slider-runnable-track]:bg-transparent 
          [&::-webkit-slider-thumb]:-mt-[16px] [&::-webkit-slider-thumb]:h-10 [&::-webkit-slider-thumb]:w-14 [&::-webkit-slider-thumb]:appearance-none 
          [&::-webkit-slider-thumb]:rounded-xl [&::-webkit-slider-thumb]:border-2 [&::-webkit-slider-thumb]:border-slate-700 [&::-webkit-slider-thumb]:bg-emerald-400 
          [&::-webkit-slider-thumb]:shadow-[0_0_16px_rgba(52,211,153,0.85),0_2px_8px_rgba(0,0,0,0.45)] 
          [&::-moz-range-track]:h-2 [&::-moz-range-track]:rounded-full [&::-moz-range-track]:bg-transparent 
          [&::-moz-range-thumb]:h-10 [&::-moz-range-thumb]:w-14 [&::-moz-range-thumb]:rounded-xl [&::-moz-range-thumb]:border-2 [&::-moz-range-thumb]:border-slate-700 
          [&::-moz-range-thumb]:bg-emerald-400 [&::-moz-range-thumb]:shadow-[0_0_16px_rgba(52,211,153,0.85),0_2px_8px_rgba(0,0,0,0.45)]" />
      </div>
      <div
        class="flex h-96 min-w-8 flex-col justify-between py-0.5 text-left font-mono text-xs tabular-nums tracking-wide text-slate-400 select-none sm:h-112 sm:min-w-9"
        aria-hidden="true">
        <% speedStepLabels.forEach(function (s) { %>
        <span class="leading-none"><%= s; %></span>
        <% }); %>
      </div>
    </div>
    <span
      class="mt-4 font-medium tracking-wide text-emerald-400 drop-shadow-[0_0_12px_rgba(52,211,153,0.35)]">Forward</span>
  </div>

  <div class="flex flex-col items-center">
    <div
      class="flex items-stretch gap-4 rounded-3xl border border-slate-700/90 bg-slate-900/95 px-5 py-6 shadow-[inset_0_1px_0_0_rgba(148,163,184,0.08)] sm:gap-5 sm:px-6">
      <div class="relative h-96 w-13 shrink-0 sm:h-112 sm:w-15">
        <div
          class="pointer-events-none absolute inset-0 rounded-full border-2 border-rose-400 bg-black/85 shadow-[0_0_18px_rgba(251,113,133,0.45),0_0_42px_rgba(251,113,133,0.12)]">
        </div>
        <input id="reverseSpeed" type="range" min="0" max="127" step="1" value="0" aria-label="Reverse speed"
          class="absolute left-1/2 top-1/2 w-96 max-w-none -translate-x-1/2 -translate-y-1/2 -rotate-90 cursor-pointer appearance-none accent-rose-500 h-14 
          [&::-webkit-slider-runnable-track]:h-2 [&::-webkit-slider-runnable-track]:rounded-full [&::-webkit-slider-runnable-track]:bg-transparent 
          [&::-webkit-slider-thumb]:-mt-[16px] [&::-webkit-slider-thumb]:h-10 [&::-webkit-slider-thumb]:w-14 [&::-webkit-slider-thumb]:appearance-none 
          [&::-webkit-slider-thumb]:rounded-xl [&::-webkit-slider-thumb]:border-2 [&::-webkit-slider-thumb]:border-slate-700 [&::-webkit-slider-thumb]:bg-rose-400 
          [&::-webkit-slider-thumb]:shadow-[0_0_16px_rgba(251,113,133,0.85),0_2px_8px_rgba(0,0,0,0.45)] 
          [&::-moz-range-track]:h-2 [&::-moz-range-track]:rounded-full [&::-moz-range-track]:bg-transparent 
          [&::-moz-range-thumb]:h-10 [&::-moz-range-thumb]:w-14 [&::-moz-range-thumb]:rounded-xl [&::-moz-range-thumb]:border-2 [&::-moz-range-thumb]:border-slate-700 
          [&::-moz-range-thumb]:bg-rose-400 [&::-moz-range-thumb]:shadow-[0_0_16px_rgba(251,113,133,0.85),0_2px_8px_rgba(0,0,0,0.45)]" />
      </div>
      <div
        class="flex h-96 min-w-8 flex-col justify-between py-0.5 text-left font-mono text-xs tabular-nums tracking-wide text-slate-400 select-none sm:h-112 sm:min-w-9"
        aria-hidden="true">
        <% speedStepLabels.forEach(function (s) { %>
        <span class="leading-none"><%= s; %></span>
        <% }); %>
      </div>
    </div>
    <span
      class="mt-4 font-medium tracking-wide text-rose-400 drop-shadow-[0_0_12px_rgba(251,113,133,0.35)]">Reverse</span>
  </div>
</div>


<script>
  const forwardSpeed = document.getElementById("forwardSpeed");
  const reverseSpeed = document.getElementById("reverseSpeed");
  const speedometer = document.getElementById("speedometer");

  const throttleByCab = {};

  function applyThrottleToControls(cab) {
    if (!cab) {
      return;
    }
    const throttle = throttleByCab[String(cab)];
    if (!throttle) {
      return;
    }
    const speed = Number(throttle.speed) || 0;
    const dir = Number(throttle.dir) === 0 ? 0 : 1;
    forwardSpeed.value = dir === 1 ? speed : 0;
    reverseSpeed.value = dir === 0 ? speed : 0;
  }

  forwardSpeed.addEventListener("input", (e) => {
    reverseSpeed.value = 0;
    speedometer.textContent = e.target.value;
    socket.emit('dcc:setThrottle', { cab: selectedTrain, speed: e.target.value, dir: 1 });
  });
  reverseSpeed.addEventListener("input", (e) => {
    forwardSpeed.value = 0;
    speedometer.textContent = `-${e.target.value}`;
    socket.emit('dcc:setThrottle', { cab: selectedTrain, speed: e.target.value, dir: 0 })
  });

  document.addEventListener("DOMContentLoaded", () => {
    const stopBtn = document.getElementById("dcc-stop");
    stopBtn.addEventListener("click", () => {
      forwardSpeed.value = 0;
      reverseSpeed.value = 0;
      socket.emit('dcc:setThrottle', { cab: selectedTrain, speed: 0, dir: 0 });
    });
  });

  socket.on('dcc:status', ({ throttleByCab: currentThrottleByCab }) => {
    if (!currentThrottleByCab || typeof currentThrottleByCab !== 'object') {
      return;
    }
    Object.assign(throttleByCab, currentThrottleByCab);
    applyThrottleToControls(selectedTrain);
  });

  socket.on('dcc:throttle', ({ cab, speed, dir }) => {
    if (cab === undefined || cab === null) {
      return;
    }
    throttleByCab[String(cab)] = { speed, dir };
    if (String(cab) === String(selectedTrain)) {
      applyThrottleToControls(selectedTrain);
    }
  });

  document.addEventListener('selectedTrain:changed', (event) => {
    const cab = event?.detail?.cab;
    applyThrottleToControls(cab);
  });

</script>