
<div class="grid grid-cols-1 gap-3 md:grid-cols-2">
  <button id="dcc-power-on" type="button"
    class="flex items-center justify-center gap-2 rounded-xl border border-emerald-400/80 bg-emerald-950/30 px-4 py-4 text-sm font-semibold uppercase tracking-wide text-emerald-300 transition hover:bg-emerald-900/40">
    <span aria-hidden="true">⚡</span>
    <span>Power On</span>
  </button>
  <button id="dcc-power-off" type="button"
    class="flex items-center justify-center gap-2 rounded-xl border border-rose-400/80 bg-rose-500 px-4 py-4 text-sm font-semibold uppercase tracking-wide text-slate-900 transition hover:bg-rose-400">
    <span aria-hidden="true">○</span>
    <span>Power Off</span>
  </button>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const powerOnBtn = document.getElementById('dcc-power-on');
    const powerOffBtn = document.getElementById('dcc-power-off');
    const powerOnBaseClass = 'flex items-center justify-center gap-2 rounded-xl border px-4 py-4 text-sm font-semibold uppercase tracking-wide transition';
    const powerOffBaseClass = 'flex items-center justify-center gap-2 rounded-xl border px-4 py-4 text-sm font-semibold uppercase tracking-wide transition';

    function setPower(power) {
      if (power) {
        powerOnBtn.className = `${powerOnBaseClass} border-emerald-300 bg-emerald-400 text-slate-900 hover:bg-emerald-300`;
        powerOffBtn.className = `${powerOffBaseClass} border-rose-500 bg-rose-950/20 text-rose-500 hover:bg-rose-950/40`;
        return;
      }

      powerOnBtn.className = `${powerOnBaseClass} border-emerald-400/80 bg-emerald-950/30 text-emerald-300 hover:bg-emerald-900/40`;
      powerOffBtn.className = `${powerOffBaseClass} border-rose-400/80 bg-rose-500 text-slate-900 hover:bg-rose-400`;
    }

    powerOnBtn.addEventListener('click', () => socket.emit('dcc:power:on'));
    powerOffBtn.addEventListener('click', () => socket.emit('dcc:power:off'));

    socket.on('dcc:power', (payload) => setPower(payload.power));
    socket.on('dcc:status', (payload) => setPower(payload.power));

    socket.emit('dcc:status');
  });
</script>